---
import { site } from '../data/site';
import { getLocaleSwitch, getNavigation, isNavigationActive, type Locale } from '../lib/locale';

interface Props {
  locale?: Locale;
}

const { locale = 'zh' } = Astro.props;
const currentPath = Astro.url.pathname;
const usesWideHeader = currentPath === '/blog' || currentPath === '/projects';
const navigation = getNavigation(locale);
const localeHref = getLocaleSwitch(currentPath, locale);
const languageLabel = locale === 'en' ? 'English' : '中文';
const languageAriaLabel = locale === 'en' ? '切换到中文' : '切换到 English';
---
<header
  class:list={['floating-header', { 'floating-header--wide': usesWideHeader }]}
  data-site-header
  data-scrolled="false"
>
  <div class="floating-header__bar">
    <a class="text-xl font-bold tracking-tight sm:text-2xl" href={locale === 'en' ? '/en' : '/'}>{site.title}</a>

    <nav aria-label={locale === 'en' ? 'Main navigation' : '主导航'} class="floating-header__nav hidden items-center gap-1 md:flex">
      {navigation.map((item) => (
        <a
          href={item.href}
          aria-current={isNavigationActive(currentPath, item.href) ? 'page' : undefined}
          class:list={['rounded-xl px-3 py-2 muted transition hover:text-[var(--ink)]', isNavigationActive(currentPath, item.href) && '!text-[var(--ink)]']}
        >
          {item.label}
        </a>
      ))}
      <a class="header-action ml-1" href="/blog#search" data-header-search aria-label={locale === 'en' ? 'Search articles' : '搜索文章'}>
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M10.8 3.6a7.2 7.2 0 1 1-4.53 12.8 7.2 7.2 0 0 1 4.53-12.8Zm0 2a5.2 5.2 0 1 0 0 10.4 5.2 5.2 0 0 0 0-10.4Zm5.06 9.01 4.58 4.58-1.42 1.42-4.57-4.58 1.41-1.42Z" fill="currentColor"/>
        </svg>
      </a>
      <a class="header-language" href={localeHref} aria-label={languageAriaLabel}>
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M12 2a10 10 0 1 1 0 20 10 10 0 0 1 0-20Zm6.95 9a7.01 7.01 0 0 0-2.03-4.34A15.6 15.6 0 0 1 15.97 11h2.98Zm-6.19-6.9A13.43 13.43 0 0 0 11.94 11h-3.9c.18-2.55 1.04-5.13 2.28-6.6.54-.2 1.1-.3 1.68-.3.26 0 .51.01.76.04v-.04ZM5.05 13a7.01 7.01 0 0 0 2.03 4.34c.49-1.35.8-2.82.95-4.34H5.05Zm5 0c.18 2.55 1.04 5.13 2.28 6.6a7.87 7.87 0 0 0 1.35 0c1.24-1.47 2.1-4.05 2.28-6.6h-5.91Zm5.92 0a15.6 15.6 0 0 1-.95 4.34A7.01 7.01 0 0 0 18.95 13h-2.98ZM8.03 11c.15-1.52.46-2.99.95-4.34A7.01 7.01 0 0 0 5.05 11h2.98Z" fill="currentColor"/>
        </svg>
        <span>{languageLabel}</span>
      </a>
      <button class="header-action" type="button" data-theme-toggle aria-label={locale === 'en' ? 'Toggle theme' : '切换主题'}>◐</button>
    </nav>

    <div class="flex items-center gap-2 md:hidden">
      <a class="header-action" href="/blog#search" data-header-search aria-label={locale === 'en' ? 'Search articles' : '搜索文章'}>
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M10.8 3.6a7.2 7.2 0 1 1-4.53 12.8 7.2 7.2 0 0 1 4.53-12.8Zm0 2a5.2 5.2 0 1 0 0 10.4 5.2 5.2 0 0 0 0-10.4Zm5.06 9.01 4.58 4.58-1.42 1.42-4.57-4.58 1.41-1.42Z" fill="currentColor"/>
        </svg>
      </a>
      <a class="header-language header-language--compact" href={localeHref} aria-label={languageAriaLabel}>{languageLabel}</a>
      <details class="relative">
        <summary class="header-action cursor-pointer list-none" aria-label={locale === 'en' ? 'Open menu' : '打开菜单'}>☰</summary>
        <nav aria-label={locale === 'en' ? 'Mobile navigation' : '移动端导航'} class="site-panel absolute right-0 top-12 z-10 flex min-w-40 flex-col p-2">
          {navigation.map((item) => <a class="rounded-lg px-4 py-2" href={item.href}>{item.label}</a>)}
          <button class="rounded-lg px-4 py-2 text-left" type="button" data-theme-toggle aria-label={locale === 'en' ? 'Toggle theme' : '切换主题'}>{locale === 'en' ? 'Theme' : '切换主题'}</button>
        </nav>
      </details>
    </div>
  </div>
</header>
<div class="floating-header__spacer" aria-hidden="true"></div>

<script is:inline>
  (() => {
    const header = document.querySelector('[data-site-header]');
    if (!(header instanceof HTMLElement)) return;

    const syncScrolled = () => {
      header.dataset.scrolled = String(window.scrollY > 24);
    };

    syncScrolled();
    window.addEventListener('scroll', syncScrolled, { passive: true });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) return;
      const searchLink = event.target.closest('[data-header-search]');
      const searchInput = document.querySelector('#post-search');
      if (!searchLink || !(searchInput instanceof HTMLInputElement)) return;

      event.preventDefault();
      searchInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
      searchInput.focus({ preventScroll: true });
      history.replaceState(null, '', '#search');
    });
  })();
</script>
