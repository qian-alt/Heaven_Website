<script is:inline>
  (() => {
    const storageKey = 'heaven-theme';
    const stored = localStorage.getItem(storageKey);
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const dark = stored ? stored === 'dark' : prefersDark;
    document.documentElement.classList.toggle('dark', dark);
    const syncToggleLabels = () => {
      const english = document.documentElement.lang === 'en';
      const label = document.documentElement.classList.contains('dark')
        ? (english ? 'Switch to light theme' : '切换到浅色主题')
        : (english ? 'Switch to dark theme' : '切换到深色主题');
      document.querySelectorAll('[data-theme-toggle]').forEach((control) => {
        control.setAttribute('aria-label', label);
      });
    };

    document.addEventListener('DOMContentLoaded', syncToggleLabels);

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) return;
      const button = event.target.closest('[data-theme-toggle]');
      if (!button) return;

      const nextDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem(storageKey, nextDark ? 'dark' : 'light');
      syncToggleLabels();
    });
  })();
</script>
