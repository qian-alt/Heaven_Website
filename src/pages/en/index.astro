---
import ExperienceCard from '../../components/ExperienceCard.astro';
import ProfileHero from '../../components/ProfileHero.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { englishProfile } from '../../data/site.en';

const featuredProjects = englishProfile.projects.filter((project) => project.featured).slice(0, 4);
---
<BaseLayout locale="en" title={englishProfile.title} description={englishProfile.description}>
  <main class="mx-auto max-w-5xl px-5 pb-8">
    <section class="home-shell px-1 pt-4 sm:px-0 sm:pt-8">
      <ProfileHero profile={englishProfile} />

      <section class="home-about mt-10">
        <h2 class="text-xl font-semibold">About</h2>
        <div class="home-about__content">
          <p class="home-about__role muted">{englishProfile.role} /</p>
          <p class="home-about__intro muted">{englishProfile.intro}</p>
          <a class="home-about__link" href="/en/about">More about me <span aria-hidden="true">›</span></a>
        </div>
      </section>

      <section class="mt-9 grid gap-4 md:grid-cols-[8.5rem_minmax(0,1fr)] md:gap-5">
        <h2 class="text-xl font-semibold md:pt-4">Education</h2>
        <div class="grid gap-3">
          {englishProfile.experiences.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </section>

      <section class="mt-9">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">Featured Projects</h2>
          <a class="text-sm accent-link" href="/projects">View all →</a>
        </div>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {featuredProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </section>
    </section>
  </main>
</BaseLayout>
