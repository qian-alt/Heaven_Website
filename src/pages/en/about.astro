---
import ExperienceCard from '../../components/ExperienceCard.astro';
import ProfileHero from '../../components/ProfileHero.astro';
import SiteInformation from '../../components/SiteInformation.astro';
import StudyProgress from '../../components/StudyProgress.astro';
import { englishProfile } from '../../data/site.en';
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout locale="en" title="About" description={englishProfile.description}>
  <main class="mx-auto max-w-4xl px-5 pb-14">
    <section class="site-panel p-6 sm:p-9">
      <ProfileHero profile={englishProfile} />

      <div class="mt-10 space-y-4 leading-8 muted">
        <h2 class="text-xl font-semibold text-[var(--ink)]">About Me</h2>
        {englishProfile.about.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <StudyProgress title="University Progress" subtitle="Stay curious, grow steadily." />

      <section class="mt-10 grid gap-4 md:grid-cols-[8.5rem_minmax(0,1fr)] md:gap-5">
        <h2 class="text-xl font-semibold md:pt-4">Education</h2>
        <div class="grid gap-3">
          {englishProfile.experiences.map((experience) => <ExperienceCard experience={experience} />)}
        </div>
      </section>
      <SiteInformation
        title="Site Information"
        distributionTitle="Distribution"
        distributionIntro="To provide a reliable visiting experience, this site is available through the following synchronized deployments."
        copyrightTitle="Copyright"
        copyrightBeforeLicense="Unless otherwise stated, original content and original page design on this site are licensed under "
        copyrightAfterLicense=". Attribution and a link to the original are required; commercial use is not permitted; adaptations must use the same license."
        thirdPartyText="Third-party images, fonts, trademarks, and other materials remain the property of their respective rights holders. Please contact me for removal if any material infringes your rights."
        themeTitle="Theme"
        themePrefix="This site is built with "
        themeMiddle=". Its interface design references "
        themeSuffix=" and has been reimplemented for my own content."
      />
    </section>
  </main>
</BaseLayout>
