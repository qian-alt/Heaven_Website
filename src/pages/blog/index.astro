---
import { getCollection } from 'astro:content';
import EmptyState from '../../components/EmptyState.astro';
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { filterPublishedPosts, getAllCollections, getAllTags, sortPosts } from '../../lib/content';

const posts = sortPosts(filterPublishedPosts(await getCollection('blog')));
const collections = getAllCollections(posts);
const tags = getAllTags(posts);
const collectionCounts = collections.map((collection) => ({
  collection,
  count: posts.filter((post) => post.data.collection === collection).length,
}));
---
<BaseLayout title="博客" description="学习记录与技术文章">
  <main class="mx-auto grid max-w-6xl gap-7 px-5 pb-14 lg:grid-cols-[minmax(0,1fr)_20rem] lg:gap-x-10">
    <header class="scroll-mt-28 lg:col-start-1" id="search">
      <h1 class="text-4xl font-semibold tracking-tight">博客</h1>
      <p class="mt-3 text-lg muted">记录学习过程、项目实践与日常思考。</p>
      <p class="mt-8 text-sm muted">共 {posts.length} 篇文章</p>
      <label class="sr-only" for="post-search">搜索文章</label>
      <input
        id="post-search"
        data-post-search
        class="mt-5 w-full rounded-2xl border bg-[var(--panel)] px-5 py-3.5 outline-none"
        placeholder="搜索标题或摘要"
      />
    </header>

    <section class="order-2 space-y-5 lg:order-none lg:col-start-1" data-post-list>
      {posts.map((post) => (
        <div
          data-post
          data-title={post.data.title.toLowerCase()}
          data-description={post.data.description.toLowerCase()}
          data-collection={post.data.collection}
          data-tags={post.data.tags.join('|')}
        >
          <PostCard post={post} />
        </div>
      ))}
      {!posts.length && <EmptyState message="还没有公开文章。" />}
      <p class="site-panel hidden px-6 py-12 text-center muted" data-filter-empty>没有匹配的文章。</p>
    </section>

    <aside class="order-1 space-y-8 lg:order-none lg:col-start-2 lg:row-start-1 lg:row-span-2 lg:pt-2">
      <section>
        <h2 class="mb-4 text-2xl font-semibold">合集</h2>
        <div class="space-y-3" aria-label="合集筛选">
          <button
            class="flex w-full items-center justify-between rounded-2xl border bg-[var(--accent-soft)] px-5 py-4 text-left transition"
            type="button"
            data-collection-filter=""
            aria-pressed="true"
          >
            <span>全部文章</span>
            <span class="muted">{posts.length}</span>
          </button>
          {collectionCounts.map(({ collection, count }) => (
            <button
              class="flex w-full items-center justify-between rounded-2xl border bg-[var(--panel)] px-5 py-4 text-left transition hover:border-[var(--accent)]"
              type="button"
              data-collection-filter={collection}
              aria-pressed="false"
            >
              <span>{collection}</span>
              <span class="muted">{count}</span>
            </button>
          ))}
        </div>
      </section>

      <section>
        <h2 class="mb-4 text-2xl font-semibold">标签</h2>
        <div class="flex flex-wrap gap-2" aria-label="标签筛选">
          <button class="rounded-full border bg-[var(--accent-soft)] px-4 py-2 text-sm" type="button" data-tag-filter="" aria-pressed="true">全部</button>
          {tags.map((tag) => (
            <button class="rounded-full border bg-[var(--panel)] px-4 py-2 text-sm muted transition hover:border-[var(--accent)]" type="button" data-tag-filter={tag} aria-pressed="false">{tag}</button>
          ))}
        </div>
      </section>
    </aside>
  </main>
</BaseLayout>
<script>
  let activeCollection = '';
  let activeTag = '';
  const search = document.querySelector<HTMLInputElement>('[data-post-search]');
  const posts = [...document.querySelectorAll<HTMLElement>('[data-post]')];
  const empty = document.querySelector<HTMLElement>('[data-filter-empty]');
  const collectionButtons = [...document.querySelectorAll<HTMLButtonElement>('[data-collection-filter]')];
  const tagButtons = [...document.querySelectorAll<HTMLButtonElement>('[data-tag-filter]')];

  const selectButton = (buttons: HTMLButtonElement[], active: HTMLButtonElement) => {
    buttons.forEach((button) => {
      const selected = button === active;
      button.classList.toggle('bg-[var(--accent-soft)]', selected);
      button.classList.toggle('bg-[var(--panel)]', !selected);
      button.setAttribute('aria-pressed', String(selected));
    });
  };

  const applyFilter = () => {
    const query = search?.value.trim().toLowerCase() ?? '';
    let visiblePosts = 0;

    posts.forEach((post) => {
      const text = `${post.dataset.title} ${post.dataset.description}`;
      const tags = post.dataset.tags?.split('|') ?? [];
      const matchesQuery = !query || text.includes(query);
      const matchesCollection = !activeCollection || post.dataset.collection === activeCollection;
      const matchesTag = !activeTag || tags.includes(activeTag);
      const visible = matchesQuery && matchesCollection && matchesTag;
      post.classList.toggle('hidden', !visible);
      if (visible) visiblePosts += 1;
    });

    empty?.classList.toggle('hidden', visiblePosts !== 0 || posts.length === 0);
  };

  search?.addEventListener('input', applyFilter);
  collectionButtons.forEach((button) => {
    button.addEventListener('click', () => {
      activeCollection = button.dataset.collectionFilter ?? '';
      selectButton(collectionButtons, button);
      applyFilter();
    });
  });
  tagButtons.forEach((button) => {
    button.addEventListener('click', () => {
      activeTag = button.dataset.tagFilter ?? '';
      selectButton(tagButtons, button);
      applyFilter();
    });
  });

  if (window.location.hash === '#search') {
    requestAnimationFrame(() => search?.focus());
  }
</script>
